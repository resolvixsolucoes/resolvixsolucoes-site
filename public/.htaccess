# -----------------------------------------------------------------------------
# Resolvix Soluções — configuração Apache / LiteSpeed (Hostinger)
# Este arquivo é copiado para out/.htaccess pelo Next.js em cada build,
# porque tudo em public/ vai pra raiz do export estático.
# -----------------------------------------------------------------------------

# --- Content-Type do OpenGraph image ------------------------------------------
# O Next.js gera o card social em /opengraph-image (sem extensão). Sem esta
# regra, o servidor serve como octet-stream e os scrapers do WhatsApp /
# LinkedIn / Twitter ignoram a imagem.
<Files "opengraph-image">
    ForceType image/png
</Files>

# --- 404 customizado ----------------------------------------------------------
ErrorDocument 404 /404.html

# --- Força HTTPS --------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} !on
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# --- Cache imutável pros assets do Next ---------------------------------------
# Arquivos em _next/static/ têm hash no nome → cache eterno é seguro.
# Fontes, ícones e imagens da marca também podem ficar em cache longo.
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(png|jpg|jpeg|svg|ico|webp|avif)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
    # HTML curto — permite propagar mudanças rápido.
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>
</IfModule>

# --- Compressão ---------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# --- Segurança básica ---------------------------------------------------------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>
